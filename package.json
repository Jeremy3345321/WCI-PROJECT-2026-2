{
  "name": "western-scheduling-system",
  "version": "1.0.0",
  "description": "Western Colleges Scheduling System - Desktop Application",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux",
    "build-all": "electron-builder -mwl"
  },
  "keywords": [
    "scheduling",
    "education",
    "western-colleges"
  ],
  "author": "Western Colleges",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.westerncollege.scheduling",
    "productName": "Western Scheduling System",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/**/*",
      "!dist/**/*",
      "!.git/**/*",
      "!.kiro/**/*",
      "!.vscode/**/*",
      "!CLEANUP_SUMMARY.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "favicon_io/favicon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "favicon_io/favicon.icns",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "favicon_io/favicon.png",
      "category": "Education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Western Scheduling"
    }
  }
}
